pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                git 'https://github.com/roshinigit255/jenkins-project1.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t devops-app .'
            }
        }

        stage('Run Container') {
            steps {
                sh 'docker run -d -p 3000:3000 devops-app'
            }
        }

    }
}
